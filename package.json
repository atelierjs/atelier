{
  "name": "component-lib",
  "version": "1.0.0",
  "author": "Travis Henning & Ryan Meloy",
  "description": "Custom, awesome component library",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/henningta/component-lib.git"
  },
  "main": "index.js",
  "scripts": {
    "bootstrap": "lerna bootstrap",
    "build:clean": "rm -rf dist",
    "build:scss": "gulp",
    "build:copy": "cp src/index.js dist && cp merge-package-json.js ./dist",
    "build": "npm-run-all build:clean build:scss build:copy",
    "watch": "gulp watch",
    "yalc": "cp package.json ./dist && cd dist && yalc publish --push"
  },
  "devDependencies": {
    "@babel/core": "^7.8.4",
    "babel-loader": "^8.0.6",
    "gulp": "^4.0.2",
    "gulp-autoprefixer": "^7.0.1",
    "gulp-clean-css": "^4.2.0",
    "gulp-sass": "^4.0.2",
    "lerna": "^3.20.2",
    "npm-run-all": "^4.1.5",
    "webpack": "^4.41.6",
    "webpack-merge": "^4.2.2"
  },
  "prettier": {
    "trailingComma": "es5",
    "singleQuote": true
  }
}
